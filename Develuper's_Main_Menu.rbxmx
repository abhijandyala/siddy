				<Item class="LocalScript" referent="RBX91000030beba461686ed9ccba961b9cf">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local bar = script.Parent
local TS = game:GetService("TweenService")
local CamResetEvent = game:GetService("ReplicatedStorage"):WaitForChild("Event")

local ButtonDefaultSize = UDim2.new(1, 0,0.22, 0)
local ButtonBigSize = ButtonDefaultSize + UDim2.new(0.1,0,0.025,0)
local ButtonSmallSize = ButtonDefaultSize - UDim2.new(0.1,0,0.024,0)

local HoverSound = script.Parent:WaitForChild("hover Sound")
local HoldSound = script.Parent:WaitForChild("HoldSound")
local ReleaseSound = script.Parent:WaitForChild("Release Sound")

bar.Parent.Enabled = true

-- Functions:

local function MouseHover(button : GuiButton)
	TS:Create(button, TweenInfo.new(.15), {Size = ButtonBigSize}):Play()
	HoverSound:Play()
end

local function MouseLeave(button : GuiButton)
	TS:Create(button, TweenInfo.new(.15), {Size = ButtonDefaultSize}):Play()
end

local function MouseHold(button : GuiButton)
	TS:Create(button, TweenInfo.new(.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = ButtonSmallSize}):Play()
	HoldSound:Play()
end

local function MouseRelease(button : GuiButton, name : StringValue)
	TS:Create(button, TweenInfo.new(.5, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {Size = ButtonDefaultSize}):Play()
	ReleaseSound:Play()
	
	if name == "PlayButton" then
		button.Interactable = false
		CamResetEvent:Fire(game.Players.LocalPlayer)
		script.Parent.Parent.Enabled = false
	end
end

-- Connections:

for _, v in pairs(bar:GetChildren()) do
	if v:IsA("GuiButton") then
		v.MouseEnter:Connect(function()
			MouseHover(v)
		end)
		v.MouseLeave:Connect(function()
			MouseLeave(v)
		end)
		v.MouseButton1Down:Connect(function()
			MouseHold(v)
		end)
		v.MouseButton1Up:Connect(function()
			MouseRelease(v, v.Name)
		end)
	end
end]]></ProtectedString>
